<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/popup_background"
    android:padding="12dp">

    <!-- 标题栏 -->
    <TextView
        android:id="@+id/menu_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sessions"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:paddingBottom="8dp" />

    <!-- 会话网格 - 填充中间空间 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/menu_sessions_grid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/menu_buttons_container"
        android:layout_below="@+id/menu_title"
        android:maxHeight="260dp"
        android:numColumns="2"
        android:stretchMode="columnWidth"
        android:gravity="center"
        android:clipToPadding="false" />

    <!-- 底部按钮 - 固定在底部 -->
    <LinearLayout
        android:id="@+id/menu_buttons_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:layout_alignParentBottom="true"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/menu_toggle_keyboard_button"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/action_toggle_soft_keyboard"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/menu_new_session_button"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="@string/action_new_session"
            android:textSize="13sp" />
    </LinearLayout>

</RelativeLayout>
